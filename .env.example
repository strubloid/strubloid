# Strubloid environment configuration
# Copy this file to .env and adjust the values for your local setup.

# SQLite database file (Phase 1). Switch to a postgresql:// URL when migrating.
DATABASE_URL="file:./dev.db"

# BigPickle AI provider configuration.
# Leave BIGPICKLE_API_URL empty to run in explicit DEV/FALLBACK mode.
# When set without an API key, the provider will use an unauthenticated request
# (BigPickle's public endpoint supports this).
BIGPICKLE_API_URL=""
BIGPICKLE_API_KEY=""

# Random chat compaction window in days (defaults to 30 when unset).
COMPACTION_WINDOW_DAYS="30"
