# Strubloid environment configuration
# Copy this file to .env and adjust the values for your local setup.

# SQLite database file (Phase 1). Switch to a postgresql:// URL when migrating.
DATABASE_URL="file:./dev.db"

# Zen AI (OpenCode) configuration.
# Set your API key here for development convenience, or configure it
# via the Settings page (stored in the Config table).
# Leave empty to run in DEV/FALLBACK mode (simulated responses).
ZEN_API_KEY=""

# Random chat compaction window in days (defaults to 30 when unset).
COMPACTION_WINDOW_DAYS="30"
