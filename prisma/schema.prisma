// Strubloid Prisma schema
// Phase 1 uses SQLite for simple local development.
// Switch the datasource `provider` to "postgresql" and update DATABASE_URL
// to migrate to Postgres without changing application code.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String   @default("#9ad933")
  isStarred   Boolean  @default(false)
  chats       Chat[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isStarred])
  @@index([updatedAt])
}

model Chat {
  id               String    @id @default(cuid())
  title            String
  projectId        String?
  project          Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  isRandom         Boolean   @default(false)
  useAiBrain       Boolean   @default(false)
  useRandomChats   Boolean   @default(false)
  brainProjectId   String?   // project whose brain memories to query (for random chats)
  selectedModelId  String?   @default("big-pickle")
  selectedModel    AiModel?  @relation(fields: [selectedModelId], references: [modelId])
  messages         Message[]
  compactedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([projectId])
  @@index([isRandom, createdAt])
  @@index([compactedAt])
}

model Message {
  id        String   @id @default(cuid())
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  role      String
  content   String
  createdAt DateTime @default(now())

  @@index([chatId, createdAt])
}

model MemoryEntry {
  id            String   @id @default(cuid())
  projectId     String?  // project scoping for brain retrieval
  title         String
  summary       String
  facts         String
  preferences   String?
  sourceChatIds String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([projectId, updatedAt])
  @@index([updatedAt])
}

// AI models available via various providers (Zen, NVIDIA, etc.)
model AiModel {
  id             Int      @id @default(autoincrement())
  modelId        String   @unique          // e.g. "deepseek-v4-flash"
  name           String                    // e.g. "DeepSeek V4 Flash"
  endpoint       String   @default("/v1/chat/completions") // API endpoint path
  provider       String   @default("openai") // openai, anthropic, google
  modelSource    String   @default("zen")  // source provider: "zen", "nvidia"
  description    String?
  isEnabled      Boolean  @default(true)
  isFree         Boolean  @default(false)
  inputPrice     Float?   // $ per 1M input tokens
  outputPrice    Float?   // $ per 1M output tokens
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  chats          Chat[]

  @@index([isEnabled])
  @@index([modelId])
  @@index([modelSource])
}

// Key-value configuration for app settings (API keys, preferences)
model Config {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}
